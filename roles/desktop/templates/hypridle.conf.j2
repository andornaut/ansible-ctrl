# Managed by the desktop role (tasks/idle.yml). Timeouts come from
# desktop_screen_lock_minutes and desktop_screen_off_minutes.
general {
    lock_cmd = hyprlock
    before_sleep_cmd = loginctl lock-session
    #after_sleep_cmd = brightnessctl -r
}

#listener {
#    timeout = 180 # 3min.
#    on-timeout = brightnessctl -s set 5%
#    on-resume = brightnessctl -r
#}

listener {
    timeout = {{ desktop_screen_lock_seconds }} # {{ desktop_screen_lock_minutes }}min
    on-timeout = loginctl lock-session
}

listener {
    timeout = {{ desktop_screen_off_seconds }} # {{ desktop_screen_off_minutes }}min
    on-timeout = niri msg action power-off-monitors

    # Workaround: eww closes all windows when its monitor is powered-off
    # https://github.com/elkowar/eww/issues/477#issuecomment-1159530928
    on-resume = niri msg action power-on-monitors && eww open {{ desktop_eww_bar }}
}

{% if desktop_suspend_inactive_managed and desktop_suspend_inactive_seconds | int > 0 %}
# Idle suspend. logind's IdleAction is not used here: hypridle never calls SetIdleHint, so
# logind would never learn that the session went idle. The bspwm hosts do use IdleAction,
# because xss-lock sets that hint for them.
#
# KNOWN ISSUE: this file is usually a symlink into the dotfiles repository, which every host
# shares, so a per-host desktop_suspend_inactive_minutes lands in a file that is committed
# once for all of them. Two niri hosts with different values would rewrite this block on
# every converge and fight over it in git. desktop_screen_*_minutes already has the same
# problem in this file and in the bspwm session script. It is latent while every host uses
# the same values, and there is only one niri host at most. The fix is to stop rendering
# per-host policy into dotfiles: move these timeouts to a hypridle drop-in the role owns
# outright (~/.config/hypr/hypridle.conf.d/, sourced from the repository copy), or template
# a user unit that hypridle reads, so the repository file carries no host-specific values.
listener {
    timeout = {{ desktop_suspend_inactive_seconds }} # {{ desktop_suspend_inactive_minutes }}min
    on-timeout = systemctl suspend
}
{% endif %}
