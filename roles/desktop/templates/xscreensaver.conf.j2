# Managed by the desktop role (tasks/idle.yml). Timeouts come from desktop_screen_*_minutes.
#
# lockTimeout is the gap between the blank and lock timeouts: the screen is blanked but not
# yet locked.
#
# dpmsQuickOff, fade and unfade are set explicitly, not left out: this block is appended to a
# file the role doesn't own, so a True written above it by xscreensaver-settings would
# otherwise stand. dpmsQuickOff False keeps power-off on its own timer; fade/unfade False make
# blank and wake instant.
mode:          {{ desktop_xscreensaver_mode }}
timeout:       {{ desktop_screen_blank_time }}
splash:        False
dialogTheme:   {{ desktop_xscreensaver_dialog_theme }}

fade:          False
unfade:        False

lock:          True
lockTimeout:   {{ desktop_screen_lock_delay_time }}

dpmsEnabled:   True
dpmsQuickOff:  False
dpmsStandby:   {{ desktop_screen_off_time }}
dpmsSuspend:   {{ desktop_screen_off_time }}
dpmsOff:       {{ desktop_screen_off_time }}
