[Desktop Entry]
# Managed by the desktop role (tasks/idle.yml). The daemon reads ~/.xscreensaver at startup
# and reloads it whenever it changes, so nothing restarts it. Built from source into
# /usr/local by the bspwm role, which is why this is not /usr/bin.
Exec=/usr/local/bin/xscreensaver
TryExec=/usr/local/bin/xscreensaver
Name=xscreensaver
Comment=Blank, lock and power down an idle X session
Type=Application
