#!/bin/sh
# Managed by the desktop role (tasks/idle.yml). An xsecurelock saver module: xsecurelock runs
# it with the window to draw in named by XSCREENSAVER_WINDOW, and kills it on unlock.
#
# Its whole job is to tell a locked screen from a merely blanked one. Both are black, and only
# the locked one has grabbed the keyboard: anything typed during the blank-to-lock grace period
# reaches whatever window has focus underneath, so a black screen with nothing on it must never
# be trusted with a password. The screen still goes fully black once
# XSECURELOCK_BLANK_TIMEOUT elapses and the monitor powers down.
#
# xterm is the drawing surface because -into reparents it into a window it did not create, and
# nothing else installed here can do that. It is not a usable terminal: the locker holds the
# keyboard and the pointer, and the shell below never reads its input.
set -eu

[ -n "${XSCREENSAVER_WINDOW:-}" ] || exit 1

# -fn is passed even though -fa selects the font that is actually drawn: a loose `*font`
# resource in the user's X resources binds to xterm's `font`, which takes a core X font name
# and not the `xft:` spec that urxvt reads there. xterm warns and falls back on every start
# without this.
exec xterm -into "$XSCREENSAVER_WINDOW" \
    -b 0 -bw 0 +sb \
    -bg '{{ desktop_xsecurelock_background_color }}' \
    -fg '{{ desktop_xsecurelock_foreground_color }}' \
    -fn fixed \
    -fa '{{ desktop_xsecurelock_font }}' -fs 24 \
    -e sh -c 'printf "\033[?25l"
              while :; do
                printf "\033[H\033[2J\n  Locked  %s\n" "$(date +%H:%M)"
                sleep 30
              done'
