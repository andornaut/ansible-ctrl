#!/bin/sh
# Managed by the desktop role (tasks/idle.yml). Started by the autostart entry it writes, so
# it runs once per X session. Timeouts come from desktop_screen_*_minutes.
#
# The clock is the X server's: `xset s <timeout> <cycle>` blanks the screen after <timeout>,
# and xss-lock starts the locker one <cycle> later, which makes <cycle> the blank-to-lock
# grace period. Neither may be zero: `xset s <timeout> 0` disables cycling, and the session
# would blank but never lock.
#
# xsecurelock is configured through the environment, which it reads from this process. What is
# not set here is left at its default, including the prompt's colours and font.
#
# Authentication needs nothing configured and nothing setuid: xsecurelock authenticates
# against the PAM service compiled into the Ubuntu package, which is common-auth, and pam_unix
# reaches /etc/shadow through the unix_chkpwd helper.
set -eu

# `xset s blank` is not the default everywhere and xscreensaver used to turn it off (it drew
# its own blank screen), which sticks in the server. Without it the screensaver still
# activates on the timeout, and xss-lock still locks one cycle later, but the screen does not
# go black in between: the desktop stays on display for the whole grace period.
xset s blank
xset s {{ desktop_screen_blank_seconds }} {{ desktop_xsecurelock_grace_seconds }}
xset dpms {{ desktop_screen_off_seconds }} {{ desktop_screen_off_seconds }} {{ desktop_screen_off_seconds }}

XSECURELOCK_PASSWORD_PROMPT='{{ desktop_xsecurelock_password_prompt }}'
# The prompt is the username and the password field, nothing else: the date, the time, the
# hostname and the keyboard layout are all things the person typing already knows. The layout
# is worth a word, since xsecurelock shows it by default for a reason: it is a hint when a
# password keeps failing because the wrong layout is active. These hosts have one layout.
XSECURELOCK_SHOW_DATETIME=0
XSECURELOCK_SHOW_HOSTNAME=0
XSECURELOCK_SHOW_KEYBOARD_LAYOUT=0
# xsecurelock powers the monitor down on a clock of its own, which starts when it locks, so
# this is what is left of the power-off timeout once the lock timeout has elapsed. Without it
# the monitor would go dark ten minutes after locking (the upstream default) whatever
# desktop_screen_off_minutes says.
XSECURELOCK_BLANK_TIMEOUT={{ desktop_xsecurelock_blank_seconds }}
XSECURELOCK_BLANK_DPMS_STATE=off
export XSECURELOCK_BLANK_DPMS_STATE XSECURELOCK_BLANK_TIMEOUT \
    XSECURELOCK_PASSWORD_PROMPT XSECURELOCK_SHOW_DATETIME XSECURELOCK_SHOW_HOSTNAME \
    XSECURELOCK_SHOW_KEYBOARD_LAYOUT

# -l holds a logind sleep inhibitor until the locker has taken the screen, so a suspend locks
# first and cannot flash the desktop on resume. xss-lock also answers logind's Lock signal,
# which is what the session's `loginctl lock-session` keybinding sends.
#
# -n is what makes the cycle a grace period, and it is required even though there is nothing
# to notify. xss-lock only waits for the screensaver's CYCLE event when a notifier is
# configured; without one it starts the locker the moment the screensaver activates:
#
#     else if (!notifier.cmd || xss_event->forced || get_cycle_time(connection) <= 0) {
#         start_child(&locker);
#     } else if (!locker.pid)
#         start_child(&notifier);
#
# So `xss-lock -- xsecurelock` locks at the blank timeout and ignores the cycle entirely. A
# notifier that exits immediately is enough to take the other branch: the CYCLE handler only
# checks that no locker is running. Nothing warns or dims during the grace, which is the
# intent; the screen is simply blank, as the X server left it.
#
# -s names the logind session rather than letting xss-lock look it up. Left to itself it calls
# GetSessionByPID(getpid()), which only resolves for a process inside the session's cgroup
# scope. Started by dex that holds, but a human restarting this script from tmux or from an
# editor's terminal lands under user@.service instead, and the resulting xss-lock silently
# ignores logind: no Lock signal, so the session's lock keybinding does nothing, and no idle
# hint, so idle suspend never fires. The environment carries the id in either case.
if [ -n "${XDG_SESSION_ID:-}" ]; then
    exec xss-lock -n /bin/true -s "$XDG_SESSION_ID" -l -- xsecurelock
fi
exec xss-lock -n /bin/true -l -- xsecurelock
