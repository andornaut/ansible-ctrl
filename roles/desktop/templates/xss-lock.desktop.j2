[Desktop Entry]
# Managed by the desktop role (tasks/idle.yml); edits are lost on the next run. Started by
# `dex --autostart` in the bspwm session. The script it runs sets the timeouts and execs
# xss-lock, so a timeout change takes effect at the next login.
Exec={{ desktop_xsecurelock_session }}
TryExec={{ desktop_xsecurelock_session }}
Name=xss-lock
Comment=Blank, lock and power down an idle X session
Type=Application
