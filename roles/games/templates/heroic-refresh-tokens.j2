#!/bin/bash
# {{ ansible_managed }}
# Runs as the games user via the heroic-token-refresh systemd service.
# All output goes to the systemd journal (journalctl -u heroic-token-refresh).
set -u
log() { echo "heroic-refresh: $*"; }

# Heroic refreshes its own tokens while running, so skip to avoid two writers.
# This is best-effort: it narrows but cannot fully close the window (Heroic could
# start mid-run). legendary/gogdl write their config atomically, so the worst case
# of an overlap is a lost refresh (fixed on the next run), not a corrupt file.
if pgrep -u "$(id -u)" -f heroic-run >/dev/null; then
  log "Heroic is running; leaving token refresh to Heroic"
  exit 0
fi

# Resolve the bundled legendary/gogdl at runtime so the arch, branch and version are
# not hardcoded (the deploy path changes on every Heroic update).
loc=$(flatpak info --show-location {{ games_heroic_app_id }} 2>/dev/null)
base="$loc/files/bin/heroic/resources/app.asar.unpacked/build/bin/x64/linux"
cfg="{{ games_heroic_config_file | dirname }}"

# refresh_store LABEL BINARY STATE_FILE CMD...
# Runs CMD (which refreshes and persists the token) only when the store's binary and
# login state both exist, and logs the outcome.
refresh_store() {
  local label=$1 binary=$2 statefile=$3
  shift 3
  if [ ! -x "$binary" ]; then
    log "$label binary not found ($binary); skipping"
  elif [ ! -f "$statefile" ]; then
    log "$label not logged in; skipping"
  elif "$@" >/dev/null 2>&1; then
    log "$label token refreshed"
  else
    log "WARNING: $label token refresh failed"
  fi
}

# Epic: legendary re-uses/refreshes the session and persists user.json.
refresh_store Epic "$base/legendary" "$cfg/legendaryConfig/legendary/user.json" \
  env LEGENDARY_CONFIG_PATH="$cfg/legendaryConfig/legendary" "$base/legendary" status

# GOG: the same 'gogdl auth' call Heroic makes to keep GOG logged in; it refreshes
# the access token from the stored refresh token. Whether gogdl persists the result
# is why the outcome is logged rather than assumed.
refresh_store GOG "$base/gogdl" "$cfg/gog_store/auth.json" \
  "$base/gogdl" --auth-config-path "$cfg/gog_store/auth.json" auth
