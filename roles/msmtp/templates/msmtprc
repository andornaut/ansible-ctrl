account default

# Relay through msmtpd on localhost, which holds the upstream credentials in
# {{ msmtp_relay_config_path }}. This file is world-readable (non-root cron senders must
# read it), so it holds no credentials.
host {{ msmtp_relay_interface }}
port {{ msmtp_relay_port }}

auth off
tls off

syslog LOG_MAIL

# https://marlam.de/msmtp/msmtp.html#Commands-specific-to-sendmail-mode
from %U@{{ msmtp_domain }}
# Replace local recipients with addresses in the aliases file
aliases /etc/aliases

# Set the From header to the envelope from address, working around Vixie Cron's invalid
# From headers. https://github.com/marlam/msmtp-mirror/issues/10
set_from_header on
