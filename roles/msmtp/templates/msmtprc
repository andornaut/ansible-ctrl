account default

# Mail is relayed through msmtpd on localhost, which holds the upstream SMTP
# credentials in {{ msmtp_relay_config_path }}. This file is world-readable so
# that non-root senders (cron drops privileges to the crontab owner before
# invoking sendmail) can submit mail, so it must not contain any credentials.
host {{ msmtp_relay_interface }}
port {{ msmtp_relay_port }}

auth off
tls off

syslog LOG_MAIL

# https://marlam.de/msmtp/msmtp.html#Commands-specific-to-sendmail-mode
from %U@{{ msmtp_domain }}
# Replace local recipients with addresses in the aliases file
aliases /etc/aliases

# Always set the "From" header to the envelope "from address".
# This is necessary to workaround Vixie Cron sending invalid "From"
# headers.
# See: https://github.com/marlam/msmtp-mirror/issues/10
set_from_header on
