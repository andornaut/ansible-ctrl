# rsnapshot.conf - managed by ansible-role-rsnapshot.
# Fields are tab-separated; backup directories require a trailing slash.

config_version	1.2

snapshot_root	{{ rsnapshot_directory }}

# System binaries for cp/rm (extra features, faster than the built-in perl routines).
cmd_cp		/bin/cp
cmd_rm		/bin/rm
cmd_rsync	/usr/bin/rsync
cmd_ssh		/usr/bin/ssh
cmd_logger	/usr/bin/logger

# Retention intervals, ascending order. A null value omits the line and its cron job.
{% if rsnapshot_retention.hourly %}
retain	hourly	{{ rsnapshot_retention.hourly }}
{% endif %}
{% if rsnapshot_retention.daily %}
retain	daily	{{ rsnapshot_retention.daily }}
{% endif %}
{% if rsnapshot_retention.weekly %}
retain	weekly	{{ rsnapshot_retention.weekly }}
{% endif %}
{% if rsnapshot_retention.monthly %}
retain	monthly	{{ rsnapshot_retention.monthly }}
{% endif %}

verbose		2
loglevel	3
logfile	/var/log/rsnapshot.log
lockfile	/var/run/rsnapshot.pid

rsync_short_args	-az
{% if rsnapshot_sudo %}
# Run the remote rsync via sudo, for paths the SSH user cannot read.
rsync_long_args	--delete --numeric-ids --relative --delete-excluded --rsync-path='sudo /usr/bin/rsync'
{% endif %}

# Backup points: directories pulled per host, then backup_script output.
{% for host in rsnapshot_hosts %}
{% for directory in host.directories|default((), true) %}
backup	{% if not host.local|default(false) and host.name != 'localhost' %}{{ host.user|default(ansible_facts['env']['USER'], true) }}@{{ host.name }}:{% endif %}{{ directory }}	{{ host.name }}/
{% endfor %}
{% for script in host.scripts|default((), true) %}
backup_script	{{ script.command }} {{ script.args }}	{{ host.name }}_{{ script.command|basename }}/
{% endfor %}
{% endfor %}
