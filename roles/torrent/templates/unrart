#!/bin/bash

set -euo pipefail

COMMAND_PREFIX="nice -n19 ionice -c3"
OUTPUT_REDIRECT="/dev/stdout"
MAX_DEPTH=5
DELETE_ARCHIVES=false
QUIET=false

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS] [DIRECTORY]

Extract archive files (rar, zip, tar.gz, tar.bz2) found in DIRECTORY
(default: {{ torrent_local_incoming_directory }}) up to ${MAX_DEPTH} levels deep.

Options:
  -h, --help             Show this help message and exit
  -q, --quiet            Suppress output
  --delete-archives      Delete archives after extraction
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        -q|--quiet)
            OUTPUT_REDIRECT="/dev/null"
            QUIET=true
            shift
            ;;
        --delete-archives)
            DELETE_ARCHIVES=true
            shift
            ;;
        *)
            break
            ;;
    esac
done

error() { echo -e " \033[1;31m✗\033[0m  $*" >&2; exit 1; }
header() { "${QUIET}" || echo -e "\n\033[1m$*\033[0m\n"; }
info() { "${QUIET}" || echo -e " \033[1;34m•\033[0m  $*"; }
ok() { "${QUIET}" || echo -e " \033[1;32m✔\033[0m  ${*-OK}"; }
warn() { "${QUIET}" || echo -e " \033[1;33m!\033[0m  $*" >&2; }

trap 'exit' INT

directory="${1:-{{ torrent_local_incoming_directory }}}"

extract() {
    local archive="$1"
    local archive_dir
    archive_dir="$(dirname "${archive}")"
    cd "${archive_dir}"

    info "${archive}"
    local rc=0
    case "${archive,,}" in
        *.rar)             ${COMMAND_PREFIX} unrar e -o- -y "${archive}" >"${OUTPUT_REDIRECT}" || rc=$? ;;
        *.tar.gz|*.tgz)    ${COMMAND_PREFIX} tar xzf "${archive}" >"${OUTPUT_REDIRECT}" || rc=$? ;;
        *.tar.bz2|*.tbz2)  ${COMMAND_PREFIX} tar xjf "${archive}" >"${OUTPUT_REDIRECT}" || rc=$? ;;
        *.zip)             ${COMMAND_PREFIX} unzip -n "${archive}" >"${OUTPUT_REDIRECT}" || rc=$? ;;
    esac

    # unrar returns 10 for minor warnings (e.g. file already exists with -o-)
    if [[ "${rc}" -ne 0 && ("${archive,,}" != *.rar || "${rc}" -ne 10) ]]; then
        error "Failed to extract ${archive} (exit code: ${rc})"
    fi

    if "${DELETE_ARCHIVES}"; then
        # RAR archives are often split into multiple parts (.rar, .r00, .r01, ...),
        # so delete all matching parts. Other formats are typically single files.
        case "${archive,,}" in
            *.rar) find "${archive_dir}" -maxdepth 1 -iregex '.*\.r[0-9a-z]+' -delete ;;
            *)     rm -f "${archive}" ;;
        esac
    fi

    cd - >/dev/null
}

header "Extracting archives in ${directory} (max depth: ${MAX_DEPTH})"

count=0
while read -r archive; do
    extract "${archive}"
    count=$((count + 1))
done < <(find "${directory}" -maxdepth "${MAX_DEPTH}" -iregex '.*\.\(rar\|zip\|tar\.gz\|tgz\|tar\.bz2\|tbz2\)')

if [[ "${count}" -eq 0 ]]; then
    warn "No archives found"
else
    ok "Extracted ${count} archive(s)"
fi
